// ─── Notifications (cross-tenant log; use system Prisma client) ─────────────
model NotificationLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  type       String
  recipient  String
  sentAt     DateTime @default(now()) @map("sent_at")
  metadata   Json?

  @@index([entityType, entityId, type])
}

// ─── Spice Krewe — city registry (Rank 9; seeded via manual SQL) ───────────
model SpiceKreweCity {
  id           String    @id @default(cuid())
  slug         String    @unique
  displayName  String    @map("display_name")
  stateCode    String    @map("state_code")
  isLive       Boolean   @default(false) @map("is_live")
  launchedAt   DateTime? @map("launched_at")
  heroImageUrl String?   @map("hero_image_url")
  tagline      String?
  createdAt    DateTime  @default(now())
}

// ─── Spice Krewe — event concierge (Rank 1) ──────────────────────────────────
model ConciergeBrief {
  id                      String             @id @default(cuid())
  tenantId                String             @map("tenant_id")
  citySlug                String             @map("city_slug")
  buyerId                 String             @map("buyer_id")
  eventType               String             @map("event_type")
  guestCount              Int                @map("guest_count")
  theme                   String?
  budgetCents             Int                @map("budget_cents")
  eventDate               DateTime?          @map("event_date")
  locationNotes           String?            @map("location_notes")
  status                  String             @default("pending")
  conciergeFeeCharged     Boolean            @default(false) @map("concierge_fee_charged")
  estimatedTotalCents     Int?               @map("estimated_total_cents")
  requiresHumanReview     Boolean            @default(false) @map("requires_human_review")
  humanReviewedAt         DateTime?          @map("human_reviewed_at")
  aiPackageJson           Json?              @map("ai_package_json")
  stripePaymentIntentId   String?            @map("stripe_payment_intent_id")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  packages                ConciergePackage[]

  @@index([tenantId, citySlug, status])
}

model ConciergePackage {
  id          String         @id @default(cuid())
  briefId     String         @map("brief_id")
  brief       ConciergeBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  packageJson Json           @map("package_json")
  status      String         @default("draft")
  acceptedAt  DateTime?      @map("accepted_at")
  createdAt   DateTime       @default(now())

  @@index([briefId])
}
