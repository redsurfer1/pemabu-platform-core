# PostgreSQL connection string (required for Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Flomisma Settlement API (Task 1)
FLOMISMA_BASE_URL="https://api.flomisma.example.com/v1"
FLOMISMA_API_KEY="your_flomisma_api_key"

# JWT / Auth (Task 2 – Clerk, Auth0, or custom)
JWT_SECRET_OR_PUBLIC_KEY="your_jwt_verification_key"
JWT_ISSUER="https://your-issuer.example.com"

# Transparent Identity (Anti-Perplexity) – injected into User-Agent for all external requests
AGENT_ID="your_agent_or_platform_id"

# Execution Sandbox (OpenAI-style)
SANDBOX_SIGNING_SECRET="your_hmac_secret_for_result_hash"
SANDBOX_DOCKER_IMAGE="node:20-alpine"
SANDBOX_TIMEOUT_SECONDS="300"
SANDBOX_USE_DOCKER="1"

# -----------------------------------------------------------------------------
# Stripe (Pemabu portal — Sprint 5)
# -----------------------------------------------------------------------------
# CLEAN MODEL: publishable key only in browser; secret key server-only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

# -----------------------------------------------------------------------------
# Revenue automation (STEP 1 + concierge)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CRON_SECRET=
PEMABU_ADMIN_SECRET=
CONCIERGE_OPS_EMAIL=
SPICE_KREWE_TENANT_ID=
CHURN_SIGNAL_THRESHOLD_DAYS=14
ANALYTICS_MARGIN_ALERT_THRESHOLD=0.80
CONCIERGE_BRIEF_EXPIRY_HOURS=48
PROVIDER_DECLINE_WINDOW_HOURS=24
CITY_MIN_PROVIDERS_TO_LAUNCH=10
COMPLIANCE_AUDIT_FEE=5000
COMPLIANCE_RETAINER_FEE=100
AI_AGENT_CONCIERGE_FEE=299
AI_AGENT_ARBITRATION_FEE=199
AI_AGENT_VERIFICATION_FEE=149
ANALYTICS_PREMIUM_FEE=149
STRIPE_PRICE_EXPLORER=
STRIPE_PRICE_ENTHUSIAST=
ANTHROPIC_CONCIERGE_MODEL=claude-sonnet-4-20250514
